{
  "jobName": "MonthlyRevenueBreakdown",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "overdraft_events",
      "schema": "datalake",
      "table": "overdraft_events",
      "columns": [
        "overdraft_id",
        "account_id",
        "customer_id",
        "fee_amount",
        "fee_waived"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "transaction_id",
        "account_id",
        "txn_type",
        "amount"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "customers",
      "schema": "datalake",
      "table": "customers",
      "columns": [
        "id",
        "first_name",
        "last_name"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.MonthlyRevenueBreakdownBuilder"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "monthly_revenue_breakdown",
      "fileName": "monthly_revenue_breakdown.csv",
      "outputTableDirName": "monthly_revenue_breakdown"
    }
  ]
}
