{
  "jobName": "CardTypeDistribution",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "cards",
      "schema": "datalake",
      "table": "cards",
      "columns": [
        "card_id",
        "customer_id",
        "card_type",
        "card_status"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "card_transactions",
      "schema": "datalake",
      "table": "card_transactions",
      "columns": [
        "card_txn_id",
        "card_id",
        "amount"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.CardTypeDistributionProcessor"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "card_type_distribution",
      "fileName": "card_type_distribution.csv",
      "outputTableDirName": "card_type_distribution"
    }
  ]
}
