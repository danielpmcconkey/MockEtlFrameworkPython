{
  "jobName": "CustomerAddressHistory",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "addresses",
      "schema": "datalake",
      "table": "addresses",
      "columns": [
        "address_id",
        "customer_id",
        "address_line1",
        "city",
        "state_province",
        "postal_code",
        "country"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "branches",
      "schema": "datalake",
      "table": "branches",
      "columns": [
        "branch_id",
        "branch_name"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "addr_history",
      "sql": "SELECT sub.customer_id, sub.address_line1, sub.city, sub.state_province, sub.postal_code, sub.country, sub.ifw_effective_date FROM (SELECT a.customer_id, a.address_line1, a.city, a.state_province, a.postal_code, a.country, a.ifw_effective_date FROM addresses a WHERE a.customer_id IS NOT NULL) sub ORDER BY sub.customer_id"
    },
    {
      "type": "ParquetFileWriter",
      "source": "addr_history",
      "outputDirectory": "Output/curated",
      "numParts": 2,
      "writeMode": "Append",
      "jobDirName": "customer_address_history",
      "fileName": "customer_address_history",
      "outputTableDirName": "customer_address_history"
    }
  ]
}
