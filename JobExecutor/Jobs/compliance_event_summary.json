{
  "jobName": "ComplianceEventSummary",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "compliance_events",
      "schema": "datalake",
      "table": "compliance_events",
      "columns": [
        "event_id",
        "customer_id",
        "event_type",
        "status"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "accounts",
      "schema": "datalake",
      "table": "accounts",
      "columns": [
        "account_id",
        "customer_id",
        "account_type",
        "account_status"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.ComplianceEventSummaryBuilder"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "compliance_event_summary",
      "fileName": "compliance_event_summary.csv",
      "outputTableDirName": "compliance_event_summary"
    }
  ]
}
