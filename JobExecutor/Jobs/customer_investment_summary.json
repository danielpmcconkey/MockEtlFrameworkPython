{
  "jobName": "CustomerInvestmentSummary",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "investments",
      "schema": "datalake",
      "table": "investments",
      "columns": [
        "investment_id",
        "customer_id",
        "account_type",
        "current_value",
        "advisor_id"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "customers",
      "schema": "datalake",
      "table": "customers",
      "columns": [
        "id",
        "first_name",
        "last_name",
        "birthdate"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "securities",
      "schema": "datalake",
      "table": "securities",
      "columns": [
        "security_id",
        "ticker",
        "security_name",
        "security_type",
        "sector"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.CustomerInvestmentSummaryBuilder"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "customer_investment_summary",
      "fileName": "customer_investment_summary.csv",
      "outputTableDirName": "customer_investment_summary"
    }
  ]
}
