{
  "jobName": "DebitCreditRatio",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "transaction_id",
        "account_id",
        "txn_type",
        "amount",
        "description"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "accounts",
      "schema": "datalake",
      "table": "accounts",
      "columns": [
        "account_id",
        "customer_id",
        "interest_rate",
        "credit_limit"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.DebitCreditRatioCalculator"
    },
    {
      "type": "ParquetFileWriter",
      "source": "output",
      "outputDirectory": "Output/curated",
      "numParts": 1,
      "writeMode": "Overwrite",
      "jobDirName": "debit_credit_ratio",
      "fileName": "debit_credit_ratio",
      "outputTableDirName": "debit_credit_ratio"
    }
  ]
}
