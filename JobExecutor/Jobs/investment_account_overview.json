{
  "jobName": "InvestmentAccountOverview",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "investments",
      "schema": "datalake",
      "table": "investments",
      "columns": [
        "investment_id",
        "customer_id",
        "account_type",
        "current_value",
        "risk_profile",
        "advisor_id"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "customers",
      "schema": "datalake",
      "table": "customers",
      "columns": [
        "id",
        "prefix",
        "first_name",
        "last_name",
        "suffix"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.InvestmentAccountOverviewBuilder"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "trailerFormat": "TRAILER|{row_count}|{date}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "investment_account_overview",
      "fileName": "investment_account_overview.csv",
      "outputTableDirName": "investment_account_overview"
    }
  ]
}
