{
  "jobName": "MonthlyTransactionTrend",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "transaction_id",
        "account_id",
        "txn_type",
        "amount"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "branches",
      "schema": "datalake",
      "table": "branches",
      "columns": [
        "branch_id",
        "branch_name"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "monthly_trend",
      "sql": "WITH base AS (SELECT ifw_effective_date, COUNT(*) AS daily_transactions, ROUND(SUM(amount), 2) AS daily_amount, ROUND(AVG(amount), 2) AS avg_transaction_amount FROM transactions WHERE ifw_effective_date >= '2024-10-01' GROUP BY ifw_effective_date) SELECT ifw_effective_date, daily_transactions, daily_amount, avg_transaction_amount FROM base ORDER BY ifw_effective_date"
    },
    {
      "type": "CsvFileWriter",
      "source": "monthly_trend",
      "includeHeader": true,
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "monthly_transaction_trend",
      "fileName": "monthly_transaction_trend.csv",
      "outputTableDirName": "monthly_transaction_trend"
    }
  ]
}
