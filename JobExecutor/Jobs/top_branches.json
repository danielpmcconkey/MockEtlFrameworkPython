{
  "jobName": "TopBranches",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "branch_visits",
      "schema": "datalake",
      "table": "branch_visits",
      "columns": [
        "visit_id",
        "branch_id"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "branches",
      "schema": "datalake",
      "table": "branches",
      "columns": [
        "branch_id",
        "branch_name"
      ]
    },
    {
      "type": "Transformation",
      "resultName": "top_branches",
      "sql": "WITH visit_totals AS (SELECT bv.branch_id, COUNT(*) AS total_visits FROM branch_visits bv WHERE bv.ifw_effective_date >= '2024-10-01' GROUP BY bv.branch_id) SELECT vt.branch_id, b.branch_name, vt.total_visits, RANK() OVER (ORDER BY vt.total_visits DESC) AS rank, b.ifw_effective_date FROM visit_totals vt JOIN branches b ON vt.branch_id = b.branch_id ORDER BY rank, vt.branch_id"
    },
    {
      "type": "CsvFileWriter",
      "source": "top_branches",
      "includeHeader": true,
      "trailerFormat": "CONTROL|{date}|{row_count}|{timestamp}",
      "writeMode": "Overwrite",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "top_branches",
      "fileName": "top_branches.csv",
      "outputTableDirName": "top_branches"
    }
  ]
}
