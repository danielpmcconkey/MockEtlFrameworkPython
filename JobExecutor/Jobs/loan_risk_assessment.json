{
  "jobName": "LoanRiskAssessment",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "loan_accounts",
      "schema": "datalake",
      "table": "loan_accounts",
      "columns": [
        "loan_id",
        "customer_id",
        "loan_type",
        "current_balance",
        "interest_rate",
        "loan_status"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "credit_scores",
      "schema": "datalake",
      "table": "credit_scores",
      "columns": [
        "credit_score_id",
        "customer_id",
        "bureau",
        "score"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "customers",
      "schema": "datalake",
      "table": "customers",
      "columns": [
        "id",
        "first_name",
        "last_name"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "segments",
      "schema": "datalake",
      "table": "segments",
      "columns": [
        "segment_id",
        "segment_name"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.LoanRiskCalculator"
    },
    {
      "type": "ParquetFileWriter",
      "source": "output",
      "outputDirectory": "Output/curated",
      "numParts": 2,
      "writeMode": "Overwrite",
      "jobDirName": "loan_risk_assessment",
      "fileName": "loan_risk_assessment",
      "outputTableDirName": "loan_risk_assessment"
    }
  ]
}
