{
  "jobName": "Customer360Snapshot",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "customers",
      "schema": "datalake",
      "table": "customers",
      "columns": [
        "id",
        "prefix",
        "first_name",
        "last_name",
        "suffix"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "accounts",
      "schema": "datalake",
      "table": "accounts",
      "columns": [
        "account_id",
        "customer_id",
        "current_balance",
        "interest_rate",
        "credit_limit",
        "apr"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "cards",
      "schema": "datalake",
      "table": "cards",
      "columns": [
        "card_id",
        "customer_id",
        "card_number_masked"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "investments",
      "schema": "datalake",
      "table": "investments",
      "columns": [
        "investment_id",
        "customer_id",
        "current_value"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.Customer360SnapshotBuilder"
    },
    {
      "type": "ParquetFileWriter",
      "source": "output",
      "outputDirectory": "Output/curated",
      "numParts": 1,
      "writeMode": "Overwrite",
      "jobDirName": "customer_360_snapshot",
      "fileName": "customer_360_snapshot",
      "outputTableDirName": "customer_360_snapshot"
    }
  ]
}
