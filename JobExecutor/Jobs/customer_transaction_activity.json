{
  "jobName": "CustomerTransactionActivity",
  "firstEffectiveDate": "2024-10-01",
  "modules": [
    {
      "type": "DataSourcing",
      "resultName": "transactions",
      "schema": "datalake",
      "table": "transactions",
      "columns": [
        "transaction_id",
        "account_id",
        "txn_type",
        "amount"
      ]
    },
    {
      "type": "DataSourcing",
      "resultName": "accounts",
      "schema": "datalake",
      "table": "accounts",
      "columns": [
        "account_id",
        "customer_id"
      ]
    },
    {
      "type": "External",
      "assemblyPath": "{ETL_ROOT}/ExternalModules/bin/Debug/net8.0/ExternalModules.dll",
      "typeName": "ExternalModules.CustomerTxnActivityBuilder"
    },
    {
      "type": "CsvFileWriter",
      "source": "output",
      "includeHeader": true,
      "writeMode": "Append",
      "lineEnding": "LF",
      "outputDirectory": "Output/curated",
      "jobDirName": "customer_transaction_activity",
      "fileName": "customer_transaction_activity.csv",
      "outputTableDirName": "customer_transaction_activity"
    }
  ]
}
